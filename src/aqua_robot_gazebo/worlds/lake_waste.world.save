<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="lake_waste_world">

    <!-- ============================================================ -->
    <!--  PHYSICS                                                       -->
    <!-- ============================================================ -->
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <gravity>0 0 -9.81</gravity>
    </physics>

    <!-- ============================================================ -->
    <!--  SUN  (directional, positioned high like midday sun)          -->
    <!-- ============================================================ -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>1.0 0.95 0.8 1</diffuse>
      <specular>0.4 0.4 0.4 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.3 0.2 -1.0</direction>
    </light>

    <!-- Ambient fill light for underwater/shadowed areas -->
    <light name="ambient_fill" type="point">
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.5 0.6 0.7 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>100</range>
        <constant>0.5</constant>
        <linear>0.01</linear>
        <quadratic>0.0</quadratic>
      </attenuation>
    </light>

    <!-- ============================================================ -->
    <!--  SKY / SCENE                                                   -->
    <!-- ============================================================ -->
    <scene>
      <sky>
        <clouds>
          <speed>8</speed>
          <humidity>0.6</humidity>
          <mean_size>0.5</mean_size>
          <ambient>0.85 0.85 0.85 1</ambient>
        </clouds>
        <time>12</time>
        <sunrise>6</sunrise>
        <sunset>20</sunset>
      </sky>
      <ambient>0.4 0.5 0.6 1</ambient>
      <background>0.53 0.81 0.98 1</background>
      <shadows>true</shadows>
      <fog>
        <color>0.8 0.9 1.0 1</color>
        <type>linear</type>
        <start>40</start>
        <end>80</end>
        <density>0.02</density>
      </fog>
    </scene>

    <!-- ============================================================ -->
    <!--  LAKE BED  (large flat plane below water)                      -->
    <!-- ============================================================ -->
    <model name="lake_bed">
      <static>true</static>
      <pose>0 0 -3.0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>80 80 0.2</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>80 80 0.2</size></box>
          </geometry>
          <material>
            <ambient>0.25 0.20 0.12 1</ambient>
            <diffuse>0.30 0.25 0.15 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!--  WATER SURFACE  (large semi-transparent blue plane at z=0)    -->
    <!-- ============================================================ -->
    <model name="water_surface">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box><size>70 70 -0.05</size></box>
          </geometry>
          <material>
            <ambient>0.05 0.25 0.45 0.75</ambient>
            <diffuse>0.08 0.35 0.60 0.75</diffuse>
            <specular>0.8 0.9 1.0 0.9</specular>
            <emissive>0.02 0.06 0.10 0</emissive>
          </material>
          <transparency>0.35</transparency>
          <cast_shadows>false</cast_shadows>
        </visual>
        <!-- No collision: robot floats on its own buoyancy plugin -->
      </link>
    </model>

    <!-- ============================================================ -->
